JWT_SECRET=change-me-in-production
# 开发用默认 Fernet 密钥；生产务必重新生成: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=
ADMIN_USER=admin
ADMIN_PASSWORD=admin123
# 货源匹配 embedder：mock（默认，worker 镜像轻量、无需 torch，docker compose up 一键跑通）。
# 切换真实 CLIP 跨平台去重需同时设置 EMBEDDER=clip 与 INSTALL_ML=true（重新 build worker 镜像装 torch/cn_clip，体积达数 GB）。
EMBEDDER=mock
INSTALL_ML=false
# 五维评分用的 LLM 服务：mock（默认，确定性桩，无需 key，用于开发/CI）。
# 切换真实 LLM 需设置 LLM_PROVIDER=openai，并配置 LLM_BASE_URL / LLM_API_KEY / LLM_MODEL（默认通义千问 DashScope）。
LLM_PROVIDER=mock
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=
LLM_MODEL=qwen-plus
