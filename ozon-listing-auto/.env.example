JWT_SECRET=change-me-in-production
# 开发用默认 Fernet 密钥；生产务必重新生成: python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=
ADMIN_USER=admin
ADMIN_PASSWORD=admin123
# 货源匹配 embedder：mock（默认，worker 镜像轻量、无需 torch，docker compose up 一键跑通）。
# 切换真实 CLIP 跨平台去重需同时设置 EMBEDDER=clip 与 INSTALL_ML=true（重新 build worker 镜像装 torch/cn_clip，体积达数 GB）。
EMBEDDER=mock
INSTALL_ML=false
# 五维评分用的 LLM 服务：mock（默认，确定性桩，无需 key，用于开发/CI）。
# 切换真实 LLM 需设置 LLM_PROVIDER=openai，并配置 LLM_BASE_URL / LLM_API_KEY / LLM_MODEL（默认通义千问 DashScope）。
LLM_PROVIDER=mock
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=
LLM_MODEL=qwen-plus
# Ozon 挂靠上架 provider：mock（默认，MockOzonSeller，无需真实凭据，全链路可跑通）。
# 切换真实挂靠需设置 OZON_SELLER_PROVIDER=real；仅异步 worker 路径（run_publish/run_publish_tick）按此选择，
# 所有 sync=true 的接口（/listing/publish?sync=true、/publish/tick?sync=true）恒用 mock，供演示/测试。
OZON_SELLER_PROVIDER=mock
# 跨进程实时进度后端：memory（默认，单进程内 WS fan-out，测试/单机足够）。
# 多进程（api 与 worker 分离）需设置 PROGRESS_BACKEND=redis，复用 REDIS_URL 走 pub/sub 广播到 /ws/progress。
PROGRESS_BACKEND=memory
# 改图 provider：mock（默认，占位产物）| local（Pillow 本地真实处理，whitebg/crop_norm/watermark）
# | openai_compat/http（外部 AI 生图，需在 /settings/imagegen 配 base_url/api_key/model）。
# rmbg 去背景需 worker 以 INSTALL_ML=true 构建（装 rembg/onnx），否则降级白底。
IMAGE_PROVIDER=mock
